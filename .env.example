# Copy this to server/.env. Server-side secrets — never commit, never ship.

PORT=3000
NODE_ENV=development

# ─── Supabase ───────────────────────────────────────────────────────────────
# Public URL (same value as the client's EXPO_PUBLIC_SUPABASE_URL).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service-role key. Bypasses RLS — keep server-side only.
# Dashboard → Project Settings → API → "service_role" (legacy) or
# "Secret keys" (new sb_secret_* format). Either works with supabase-js.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used by the Node GraphQL backend to mint access/refresh tokens.
# Use a long random value. SUPABASE_JWT_SECRET is accepted as a fallback in
# existing local envs, but APP_JWT_SECRET is the preferred name now.
APP_JWT_SECRET=

# Dev-only hardcoded OTP until SMTP/SMS is wired.
DEV_OTP_CODE=123456

# Legacy Supabase Auth JWT secret. Optional for the GraphQL MVP.
SUPABASE_JWT_SECRET=

# ─── Direct Postgres connection (postgres-js) ───────────────────────────────
# Used for transactions (seat locks, reservation creation) where supabase-js's
# REST layer would be awkward. Dashboard → Project Settings → Database →
# "Connection string" → "URI" → copy the *session-pooler* URL on port 5432
# (port 6543 = transaction pooler, doesn't support prepared statements).
DATABASE_URL=postgresql://postgres.YOUR-REF:YOUR-DB-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins. Expo's dev URL changes per tunnel session —
# leave "*" in dev, lock it down before production. Native fetch from RN
# doesn't enforce CORS at all, so this only matters for `expo start --web`.
CORS_ORIGINS=*

# ─── Redis (session cache) ─────────────────────────────────────────────
REDIS_URL=redis://:louagi-dev@localhost:6379
REDIS_SESSION_TTL=900

# ─── PII encryption at rest ─────────────────────────────────────────────────
# 32-byte key (64 hex chars, e.g. `openssl rand -hex 32`) for AES-256-GCM
# encryption of driver ID/license numbers, payout accounts, and admin TOTP
# secrets. Unset = plaintext (dev). After setting it on an existing database,
# run once: node scripts/encrypt-pii.js
PII_ENCRYPTION_KEY=

# ─── SMS delivery (login OTPs) ──────────────────────────────────────────────
# 'twilio' (set the three TWILIO_* vars) | 'log' (print to stdout, dev only)
# | empty (no delivery; dev uses the devOtp returned to the app).
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Admin step-up ──────────────────────────────────────────────────────────
# Static fallback code for admin impersonation, used only until an admin
# enrolls per-account TOTP (Profile → Security → Authenticator). Required in
# production.
ADMIN_IMPERSONATION_CODE=
